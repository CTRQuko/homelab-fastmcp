# Secrets
.env
*.key
*.pem
*.p12
secrets/
proxmox_nodes.json

# Session transcripts / conversation logs (pueden contener secrets)
conversacion.md
conversacion*.md

# Backups (pueden contener estados antiguos con secrets)
*.bak
*.bak.*
*.bak*

# PDM residual (proyecto usa uv)
pdm.toml
pdm.lock

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
.venv/
venv/
ENV/
env/

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~

# Testing
.pytest_cache/
.coverage
htmlcov/

# Logs
*.log

# Modular framework runtime artefacts (user-specific)
inventory/*.yaml
!inventory/*.yaml.example
config/.last_state.json
config/audit.log*
config/memory.db
plugins/*/
!plugins/_example/
# unifi es un plugin "wrapper-only" sin codigo propio — solo plugin.toml
# que delega a `uvx unifi-mcp-server` (paquete upstream). NO tiene repo
# separado porque seria overkill para ~30 lineas de TOML.
!plugins/unifi/

# net-tools — plugin agregado in-tree (cloudflare + pihole + adguard
# submodules). Tests usan mocks puros (pytest-httpx). El .venv/ y
# pycache se excluyen via subpatron mas abajo.
!plugins/net-tools/
plugins/net-tools/.venv/
plugins/net-tools/**/__pycache__/
plugins/net-tools/**/*.egg-info/
plugins/net-tools/.pytest_cache/
plugins/net-tools/.ruff_cache/

# Per-session Claude Code preferences — never commit
.claude/settings.local.json
.claude/
